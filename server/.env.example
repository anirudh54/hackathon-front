# Gemini via Vertex AI — authenticates with Application Default Credentials
# (run `gcloud auth application-default login`), no API key needed.
GCP_LOCATION=us-central1

# BigQuery — fixed NIPT results table (project.dataset.table)
# BQ_PROJECT_ID also doubles as the Vertex AI project above.
BQ_PROJECT_ID=
BQ_DATASET=
BQ_TABLE=NIPT_v4_2026_data_pull_patients_10k
